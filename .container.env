PODMAN_HOST=unix:///run/user/1000/podman/podman.sock
NOYRA_CONFIG=/config/config.cue
ETCD_CA_CERT=/certs/etcd-ca.crt
ETCD_CA_KEY=/certs/etcd-ca.key
ETCD_SERVER_CERT=/certs/etcd-server.crt
ETCD_SERVER_KEY=/certs/etcd-server.key
ETCD_CLIENT_CERT=/certs/etcd-client.crt
ETCD_CLIENT_KEY=/certs/etcd-client.key
